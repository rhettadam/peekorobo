# Base URL of the Peekorobo FastAPI backend.
# Local dev options:
#   1. Run the API standalone on :8000 and set this to http://localhost:8000
#   2. Or leave it as /api and let Vite's dev proxy forward to :8000 (see vite.config.ts)
VITE_API_BASE_URL=/api

# Base URL where the static search index (teams.json, events.json) is served.
# Local dev: copy data/teams.json and data/events.json into frontend/public/data/
# Production: point at your CDN/static bucket, e.g. https://static.peekorobo.com/data
VITE_SEARCH_BASE_URL=/data

# Base URL where static image assets are served (logo, team avatars, game logos,
# section icons). Local dev: leave as /assets — Vite serves the repo-root assets/
# folder automatically (see vite.config.ts). Production: point at your CDN, e.g.
# https://static.peekorobo.com/assets
VITE_ASSETS_BASE_URL=/assets

# The FRC season the app defaults to (leaderboards, home search links, etc.)
VITE_CURRENT_YEAR=2026
