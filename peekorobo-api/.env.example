# Postgres connection string. Accepts Heroku-style postgres:// (auto-rewritten).
# For Neon, use the *pooled* connection string (host contains -pooler) and sslmode=require:
#   postgresql://USER:PASSWORD@HOST-pooler.../neondb?sslmode=require
DB_URL=postgresql://user:password@host:5432/dbname

# Serve read endpoints publicly (no API key). Set to false to require keys again.
PUBLIC_READ=true

# Allowed SPA origins for CORS. "*" is fine initially; tighten to your Pages domain in prod.
CORS_ORIGINS=*

# CDN/browser cache lifetime for read responses (seconds).
CACHE_MAX_AGE=300
CACHE_STALE_WHILE_REVALIDATE=600

# Rate limit applied per API key (or per IP when anonymous).
RATE_LIMIT_DEFAULT=240/minute

# Secret used to sign user auth JWTs (HS256). MUST be set in production; a random
# value is fine. If unset, a per-process dev fallback is used (tokens invalidate
# on restart). Generate one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-long-random-string
# Auth token lifetime in days (default 30).
JWT_EXPIRE_DAYS=30
